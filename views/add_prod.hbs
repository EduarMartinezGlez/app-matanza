<body class="bg-light">

  <div class="container">
    <main>
      <div class="py-5 text-center">
        <img class="d-block mx-auto mb-4" src="" alt="" width="72" height="57">
        <h2>Checkout form</h2>
        <p class="lead">Below is an example form built entirely with Bootstrap’s form controls. Each required form group
          has a validation state that can be triggered by attempting to submit the form without completing it.</p>
      </div>

      <form action="/product" method="post" enctype="multipart/form-data">
        <div class="col-md-7 col-lg-8">
          <h4 class="mb-3">Insertando Productos</h4>
          <form class="needs-validation" novalidate>
            <div class="row g-3">
              <div class="col-sm-6">
                <label for="firstName" class="form-label">Nombre</label>
                <input type="text" name="name" class="form-control" id="Name" placeholder="" required>
                <div class="invalid-feedback">
                  Name required.
                </div>
              </div>
              <div class="col-md-4">
                <label for="state" class="form-label">Seccion</label>
                <select name="seccion" class="form-select" id="seccion" required>
                  <option value="Frutas">Frutas</option>
                  <option value="Vegetales">Vegetales</option>
                </select>
              </div>


              <div class="col-md-2">
                <label for="zip" class="form-label">Precio</label>
                <input name="price" type="number" class="form-control" id="price" placeholder="" required>
                <div class="invalid-feedback">
                  Price required.
                </div>
              </div>


              <div class="col-md-3">
                <label for="zip" class="form-label">Cantidad</label>
                <input type="number" name="amount" class="form-control" id="amount" placeholder="" required>
                <div class="invalid-feedback">
                  Amount required.
                </div>
              </div>


              <div class="col-md-3">
                <label for="state" class="form-label">Unidad de Medida</label>
                <select name="UM" class="form-select" id="UM">
                  <option value="">Lb</option>
                  <option value="">Kg</option>
                  <option value="">Unidad</option>
                </select>
              </div>


              <div class="col-md-6">
                <label for="file" class="form-label">Selecciona una imagen</label>
                <input type="file" name="file" class="form-control" id="file" accept="image/*">
                <div class="invalid-feedback">
                  Image required.
                </div>
              </div>

              <hr class="my-4">

              <button class="w-100 btn btn-primary btn-lg" type="submit">Continue to checkout</button>
          </form>
        </div>
  </div>
  </main>
  </div>

  <body>